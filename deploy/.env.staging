# Staging Environment Configuration
# Use this for testing production API with localhost access

# Authorize.net Credentials (can use test credentials)
AUTHORIZE_API_LOGIN_ID=your-api-login-id
AUTHORIZE_TRANSACTION_KEY=your-transaction-key

# Application Configuration - Staging (includes localhost for testing)
APP_BASE_URL=https://www.pondmobile.com
ALLOWED_ORIGINS=https://www.pondmobile.com,https://pondmobile.com,http://localhost:5001,http://127.0.0.1:5001

# Environment
FLASK_ENV=production
DOCKER_ENV=true
