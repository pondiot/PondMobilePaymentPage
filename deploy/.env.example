# Authorize.net Credentials
AUTHORIZE_API_LOGIN_ID=your-api-login-id
AUTHORIZE_TRANSACTION_KEY=your-transaction-key

# Application Configuration
# ⚠️ IMPORTANT: Choose the right configuration for your environment
# APP_BASE_URL is used for payment return URL after Authorize.net checkout
# ALLOWED_ORIGINS is for CORS - must match where users access the form
#
# Three environment options available:
#
# 1. Production (deploy/.env.production):
#    - Only production domains, strict CORS
#    APP_BASE_URL=https://www.pondmobile.com
#    ALLOWED_ORIGINS=https://www.pondmobile.com,https://pondmobile.com
#
# 2. Staging (deploy/.env.staging):
#    - Production API with localhost access for testing
#    APP_BASE_URL=https://www.pondmobile.com
#    ALLOWED_ORIGINS=https://www.pondmobile.com,https://pondmobile.com,http://localhost:5001,http://127.0.0.1:5001
#
# 3. Development (this file):
#    - Local development only
#    APP_BASE_URL=http://localhost:5001
#    ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# Default: Development
APP_BASE_URL=http://localhost:5001
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# Environment
FLASK_ENV=development
DOCKER_ENV=true
